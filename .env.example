# ============================================
# FUNKYBOY LLM GATEWAY — ENVIRONMENT CONFIG
# ============================================
# Copy to .env and fill in the values.

# --- SERVER ---
PORT=8090

# --- XS TIER (local/fast, Ollama) ---
XS_PROVIDER=ollama
XS_OLLAMA_URL=http://ollama:11434
XS_MODEL=dolphin-unleashed

# --- FAST TIER (cloud, low latency) ---
FAST_PROVIDER=gemini
FAST_API_KEY=your-gemini-api-key
FAST_MODEL=gemini-2.0-flash

# --- SOTA TIER (state of the art) ---
SOTA_PROVIDER=anthropic
SOTA_API_KEY=your-anthropic-api-key
SOTA_MODEL=claude-opus-4-6
